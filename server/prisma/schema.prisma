// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  GUEST
  PATIENT
  ESCORT
  ADMIN
}

enum OrderStatus {
  PENDING // 待支付
  PAID // 已支付
  CONFIRMED // 已确认
  MATCHED // 已匹配陪诊师
  IN_PROGRESS // 服务中
  EVIDENCE_COLLECTING // 取证打卡中
  MEMO_GENERATING // 报告生成中
  COMPLETED // 已完成
  CANCELLED // 已取消
  REFUNDING // 退款中
  REFUNDED // 已退款
}

enum ServiceType {
  FULL_PROCESS // 全程陪诊
  APPOINTMENT // 代约挂号
  REPORT_PICKUP // 代取报告
  VIP_TRANSPORT // 专车接送
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum RefundStatus {
  PENDING // 待审核
  APPROVED // 审核通过
  REJECTED // 审核拒绝
  PROCESSING // 退款处理中
  COMPLETED // 退款完成
  FAILED // 退款失败
}

enum PaymentMethod {
  STRIPE
  WECHAT
  ALIPAY
}

// ==================== MODELS ====================

// 用户表
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(GUEST)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  profile          UserProfile?
  escortProfile    EscortProfile?
  ordersAsPatient  Order[]         @relation("PatientOrders")
  ordersAsEscort   Order[]         @relation("EscortOrders")
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  reviewsGiven     Review[]        @relation("ReviewAuthor")
  reviewsReceived  Review[]        @relation("ReviewTarget")
  notifications    Notification[]
  escortServices   EscortService[]

  @@map("users")
}

// 用户资料表
model UserProfile {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  name             String?
  phone            String?
  avatarUrl        String? @map("avatar_url")
  bio              String?
  gender           String?
  age              Int?
  verificationNote String? @map("verification_note") // 审核备注

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// 陪诊师资料表
model EscortProfile {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  rating            Float     @default(0)
  completedOrders   Int       @default(0) @map("completed_orders")
  isVerified        Boolean   @default(false) @map("is_verified")
  specialties       String[]  // 专长，如 ["儿科", "骨科"]
  certificateNo     String?   @map("certificate_no") // 证书编号
  bio               String?
  hourlyRate        Float?    @map("hourly_rate")
  latitude          Float?    // 纬度
  longitude         Float?    // 经度
  // 信任协议相关字段
  trustScore        Float     @default(0) // 动态信任评分 (0-100)
  evidenceCount     Int       @default(0) // 累计存证数量
  lastEvidenceAt    DateTime? @map("last_evidence_at") // 最近存证时间
  verificationLevel Int       @default(1) // 验证等级 (1-5)

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("escort_profiles")
}

// 医院表
model Hospital {
  id         String   @id @default(uuid())
  name       String
  department String // 科室
  level      String // 等级，如 "三甲"
  address    String
  phone      String?
  rating     Float?
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  orders Order[]

  @@map("hospitals")
}

// 服务类型表
model Service {
  id          String      @id @default(uuid())
  name        String
  description String?
  basePrice   Float       @map("base_price")
  type        ServiceType
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  orders Order[]

  @@map("services")
}

// 订单表
model Order {
  id                String        @id @default(uuid())
  orderNo           String        @unique @default(uuid()) @map("order_no")
  patientId         String        @map("patient_id")
  escortId          String?       @map("escort_id")
  hospitalId        String?       @map("hospital_id")
  serviceId         String?       @map("service_id")
  serviceType       ServiceType   @map("service_type")
  status            OrderStatus   @default(PENDING)
  price             Float
  duration          Int           @default(1) // 服务时长（小时）
  couponCode        String?       @map("coupon_code")
  couponDiscount    Float?        @default(0) @map("coupon_discount")
  platformFee       Float         @default(10) @map("platform_fee")
  totalAmount       Float         @map("total_amount")
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  appointmentDate   DateTime?     @map("appointment_date")
  appointmentTime   String?       @map("appointment_time")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  clinicalPathwayId String?       @map("clinical_pathway_id")

  // Relations
  patient         User                 @relation("PatientOrders", fields: [patientId], references: [id])
  escort          User?                @relation("EscortOrders", fields: [escortId], references: [id])
  hospital        Hospital?            @relation(fields: [hospitalId], references: [id])
  service         Service?             @relation(fields: [serviceId], references: [id])
  messages        Message[]
  reviews         Review[]
  payment         Payment?
  statusHistory   OrderStatusHistory[]
  serviceBooking  ServiceBooking?
  clinicalPathway ClinicalPathway?     @relation(fields: [clinicalPathwayId], references: [id])
  evidence        DigitalEvidence[]
  memo            RecoveryMemo?

  // Indexes for common queries
  @@index([patientId])
  @@index([escortId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([orderNo])
  @@map("orders")
}

// 消息类型枚举
enum MessageType {
  TEXT
  IMAGE
  ORDER
  SYSTEM
}

// 消息表
model Message {
  id         String      @id @default(uuid())
  orderId    String?     @map("order_id")
  senderId   String      @map("sender_id")
  receiverId String      @map("receiver_id")
  content    String
  type       MessageType @default(TEXT)
  imageUrl   String?     @map("image_url")
  isRead     Boolean     @default(false) @map("is_read")
  createdAt  DateTime    @default(now()) @map("created_at")

  // Relations
  order    Order? @relation(fields: [orderId], references: [id])
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  // Indexes
  @@index([senderId])
  @@index([receiverId])
  @@index([orderId])
  @@index([createdAt])
  @@index([isRead])
  @@map("messages")
}

// 评价表
model Review {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  authorId  String   @map("author_id")
  targetId  String   @map("target_id")
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order  Order @relation(fields: [orderId], references: [id])
  author User  @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User  @relation("ReviewTarget", fields: [targetId], references: [id])

  @@map("reviews")
}

// 刷新令牌表 (用于 JWT 刷新)
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// 支付记录表
model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique @map("order_id")
  userId                String        @map("user_id")
  amount                Float // 支付金额 (分)
  currency              String        @default("cny") // cny 或 usd
  method                PaymentMethod // 支付方式
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  wechatOrderId         String?       @unique @map("wechat_order_id")
  wechatPrepayId        String?       @unique @map("wechat_prepay_id")
  paidAt                DateTime?     @map("paid_at")
  refundedAt            DateTime?     @map("refunded_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]

  @@map("payments")
}

// 退款记录表
model Refund {
  id             String       @id @default(uuid())
  paymentId      String       @map("payment_id")
  orderId        String       @map("order_id")
  userId         String       @map("user_id")
  amount         Float // 退款金额 (分)
  reason         String // 退款原因
  reasonType     String       @map("reason_type") // escort_cancelled, dissatisfied, schedule_conflict, other
  description    String? // 退款说明
  status         RefundStatus @default(PENDING)
  reviewedBy     String?      @map("reviewed_by") // 审核人ID
  reviewedAt     DateTime?    @map("reviewed_at")
  reviewNote     String?      @map("review_note") // 审核备注
  wechatRefundId String?      @unique @map("wechat_refund_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("refunds")
}

// 订单状态历史表
model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  status    String // 状态值
  note      String? // 备注
  createdBy String?  @map("created_by") // 操作人ID
  createdAt DateTime @default(now()) @map("created_at")

  // Relation
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

// 通知表
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String // ORDER_STATUS, MESSAGE, REVIEW, SYSTEM, PAYMENT
  title     String
  content   String
  data      Json? // 额外数据，如 { orderId: "xxx" }
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// 陪诊师服务发布表
model EscortService {
  id                String      @id @default(uuid())
  escortId          String      @map("escort_id")
  serviceType       ServiceType @map("service_type")
  title             String?
  description       String?
  pricePerHour      Float       @map("price_per_hour")
  startDate         DateTime    @map("start_date") @db.Date
  endDate           DateTime    @map("end_date") @db.Date
  availableWeekdays Int[]       @map("available_weekdays") // [1,2,3,4,5,6,7] 表示周一到周日
  timeSlots         Json        @map("time_slots") // [{"start": "09:00", "end": "12:00"}, ...]
  hospitalIds       String[]    @map("hospital_ids") // 可服务的医院ID列表
  areas             String[] // 服务区域
  tags              String[] // 专长标签
  isActive          Boolean     @default(true) @map("is_active")
  maxDailyOrders    Int         @default(3) @map("max_daily_orders")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  escort   User             @relation(fields: [escortId], references: [id], onDelete: Cascade)
  bookings ServiceBooking[]

  // Indexes
  @@index([escortId])
  @@index([serviceType])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("escort_services")
}

// 服务预约时段表
model ServiceBooking {
  id          String   @id @default(uuid())
  serviceId   String   @map("service_id")
  orderId     String?  @unique @map("order_id")
  bookingDate DateTime @map("booking_date") @db.Date
  startTime   String   @map("start_time") // HH:mm 格式
  endTime     String   @map("end_time") // HH:mm 格式
  status      String   @default("available") // available, booked, completed, cancelled
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  service EscortService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  order   Order?        @relation(fields: [orderId], references: [id])

  @@unique([serviceId, bookingDate, startTime, endTime])
  // Indexes
  @@index([serviceId])
  @@index([orderId])
  @@index([bookingDate])
  @@index([status])
  @@map("service_bookings")
}

// ==================== 架构升级：智能化与多模态扩展 ====================

// 临床路径/智能预案表
model ClinicalPathway {
  id         String   @id @default(uuid())
  disease    String // 疾病名称
  department String // 对应科室
  nodes      Json // 路径节点序列
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("clinical_pathways")
}

// 信任黑箱：数字信用存证表
model DigitalEvidence {
  id              String    @id @default(uuid())
  orderId         String    @map("order_id")
  nodeName        String    // 对应的路径节点名
  type            String    // audio, gps, photo, emotion
  url             String?   // 存证文件路径
  content         String?   // 特征内容/录音文本
  evidenceHash    String?   @unique // 密码学哈希 (SHA-256)
  verified        Boolean   @default(false) // 是否验真通过
  validationScore Float?    // 验证分数 (0-100)
  metadata        Json?     // 原始元数据 (GPS坐标、文件信息等)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([evidenceHash])
  @@map("digital_evidences")
}

// 叙事医学：康复备忘录表
model RecoveryMemo {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  content   String // 备忘录正文
  aiModel   String   @default("minimax") @map("ai_model")
  status    String   @default("generated")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("recovery_memos")
}

// 城乡接驳：中转驿站表
model TransitStation {
  id        String   @id @default(uuid())
  name      String // 驿站名称
  region    String // 所属区域
  address   String
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transit_stations")
}
